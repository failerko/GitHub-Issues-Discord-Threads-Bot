DISCORD_TOKEN=
# Forum channel the bot mirrors GitHub issues into
DISCORD_CHANNEL_ID=
# Server the slash commands are registered to
DISCORD_GUILD_ID=

GITHUB_APP_ID=
# base64 of the GitHub App .pem file, e.g. `base64 -w0 your-app.private-key.pem`
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_OWNER=
GITHUB_REPOSITORY=
# Must match the secret configured on the GitHub App's webhook
GITHUB_WEBHOOK_SECRET=
# Optional. Pins kanban sync to one GitHub Project by number (github.com/orgs/<org>/projects/<N>).
# Leave empty to auto-select, which is ambiguous if several projects are linked to the repo.
GITHUB_PROJECT_NUMBER=

# Optional, defaults to 5000
PORT=
